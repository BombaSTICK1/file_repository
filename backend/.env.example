# Backend .env.example
# Скопируйте этот файл как .env и заполните значения

# PostgreSQL URL от Neon (обязательно для продакшена)
DATABASE_URL=postgresql://user:password@host/dbname

# Секретный ключ для JWT (сгенерируйте случайную строку)
SECRET_KEY=your-secret-key-change-in-production

# Режим работы (production или development)
ENVIRONMENT=production

# URL фронтенда (для CORS)
FRONTEND_URL=https://your-frontend.onrender.com
